{
  "name": "clindraft-backend",
  "version": "1.0.0",
  "description": "ClinDraft Backend",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
