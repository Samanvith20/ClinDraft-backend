    "drizzle-orm": "^0.45.2",
    "express": "^4.19.2",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3",
    "drizzle-kit": "^0.31.10"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.14.9",
    "@types/uuid": "^10.0.0",
    "drizzle-kit": "^0.31.10"
